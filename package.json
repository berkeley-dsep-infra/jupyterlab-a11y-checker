{
  "name": "a11y-checker-monorepo",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "cd packages/core && yarn build && cd ../cli && yarn build && cd ../extension && yarn build && jupyter labextension develop --overwrite .",
    "lint": "cd packages/extension && yarn lint"
  },
  "resolutions": {
    "minimatch": ">=3.1.3",
    "tar": ">=7.5.10",
    "rollup": ">=4.59.0",
    "dompurify": ">=3.3.2",
    "serialize-javascript": ">=7.0.3"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.49.0",
    "husky": "^9.0.11",
    "prettier": "^3.7.3",
    "typescript": "~5.4.0"
  }
}
